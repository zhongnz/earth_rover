SDK_API_TOKEN=
BOT_SLUG=
CHROME_EXECUTABLE_PATH=
# MAP_ZOOM_LEVEL defaults to 18
MAP_ZOOM_LEVEL=18
# Set this only for scored mission runs.
MISSION_SLUG=
# Image quality between 0.1 and 1.0 (default: 0.8)
IMAGE_QUALITY=0.8
# Image format: jpeg, png, webp (default: png)
IMAGE_FORMAT=jpeg
# Browser settings for browser_service.py
# Supported engines: webkit, chromium, firefox
BROWSER_ENGINE=webkit
# In containers/CI, set true. For local interactive runs, false is typical.
BROWSER_HEADLESS=false
# Override only if SDK is not running on localhost:8000.
SDK_BASE_URL=http://127.0.0.1:8000

# Optional GPS SAM2 backend settings (erc_autonomy.run_gps).
# Use scripts/setup_sam2.sh to download these assets locally.
SAM2_MODEL_CFG=
SAM2_CHECKPOINT=
SAM2_DEVICE=auto
SAM2_MAX_SIDE=1024
SAM2_POINTS_PER_SIDE=24
SAM2_PRED_IOU_THRESH=0.8
SAM2_STABILITY_SCORE_THRESH=0.9
SAM2_MIN_MASK_REGION_AREA=0
