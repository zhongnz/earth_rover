SDK_API_TOKEN=
BOT_SLUG=
CHROME_EXECUTABLE_PATH=
# MAP_ZOOM_LEVEL defaults to 18
MAP_ZOOM_LEVEL=18
# Set this only for scored mission runs.
MISSION_SLUG=
# Image quality between 0.1 and 1.0 (default: 0.8)
IMAGE_QUALITY=0.8
# Image format: jpeg, png, webp (default: png)
IMAGE_FORMAT=jpeg
# Browser settings for browser_service.py
# Supported engines: webkit, chromium, firefox
BROWSER_ENGINE=webkit
# In containers/CI, set true. For local interactive runs, false is typical.
BROWSER_HEADLESS=false
# Override only if SDK is not running on localhost:8000.
SDK_BASE_URL=http://127.0.0.1:8000
INDOOR_SDK_URL=http://127.0.0.1:8000

# Optional indoor VLM endpoint for indoor_nav/run_indoor.py.
# Keep this on a different port from the SDK bridge above.
VLM_ENDPOINT=http://127.0.0.1:8001/v1
VLM_MODEL=Qwen/Qwen2.5-VL-7B-Instruct
VLM_API_KEY=

# Optional indoor SLAM sidecar settings.
# Keep SLAM disabled until a sidecar process, ORB vocabulary, and camera
# calibration file are all available.
SLAM_BACKEND=off
SLAM_MODE=mono
SLAM_ENDPOINT=http://127.0.0.1:8765
SLAM_VOCAB_PATH=external/ORB_SLAM3/Vocabulary/ORBvoc.txt
SLAM_SETTINGS_PATH=indoor_nav/slam/calib/front_camera.yaml

# Optional GPS SAM2 backend settings (erc_autonomy.run_gps).
# Use scripts/setup_sam2.sh to download these assets locally.
SAM2_MODEL_CFG=
SAM2_CHECKPOINT=
SAM2_DEVICE=auto
SAM2_MAX_SIDE=1024
SAM2_POINTS_PER_SIDE=24
SAM2_PRED_IOU_THRESH=0.8
SAM2_STABILITY_SCORE_THRESH=0.9
SAM2_MIN_MASK_REGION_AREA=0
